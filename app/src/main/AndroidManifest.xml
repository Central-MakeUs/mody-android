<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ 푸시 알림 표시 권한(런타임 요청 필요) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Android 11+ 패키지 가시성: 카카오톡 설치 여부 확인(isKakaoTalkSharingAvailable) -->
    <queries>
        <package android:name="com.kakao.talk" />
    </queries>

    <application
        android:name=".ModyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Mody"
        tools:targetApi="31">

        <!-- FCM 수신 서비스 -->
        <service
            android:name=".notification.ModyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- notification 페이로드가 채널 미지정으로 올 때 쓸 기본 채널/아이콘 -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="mody_default" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_notification" />

        <!-- 카카오 로그인 리다이렉트 처리 (scheme = kakao{네이티브키}) -->
        <activity
            android:name="com.kakao.sdk.auth.AuthCodeHandlerActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:host="oauth"
                    android:scheme="kakao${KAKAO_NATIVE_KEY}" />
            </intent-filter>
        </activity>
    </application>

</manifest>
